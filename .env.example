# ---------------------------------------------------------------------------
# Pilotage — app monorepo · example environment
# Copy to `.env` for local dev. NEVER commit a real .env. In AWS, these come
# from Secrets Manager / SSM (see docs/RUNBOOK.md), not from files.
# ---------------------------------------------------------------------------

# --- Shared ---------------------------------------------------------------
NODE_ENV=development
PILOTAGE_ENV=dev                      # dev | staging | prod
AWS_REGION=eu-west-3                  # Paris — data residency / RGPD

# --- Database (local docker-compose Postgres) -----------------------------
# In AWS the API connects through RDS Proxy; locally it talks straight to PG.
DATABASE_URL=postgres://pilotage:pilotage@localhost:5432/pilotage
# Role the API authenticates as (RW on core, SELECT on ingest/analytics).
DATABASE_APP_ROLE=app_rw

# --- API (apps/api) -------------------------------------------------------
API_PORT=3000
API_BASE_URL=http://localhost:3000
# Comma-separated list of allowed web origins for CORS (platform + marketing site).
CORS_ORIGINS=http://localhost:5173,http://localhost:4321

# --- Auth (Amazon Cognito) ------------------------------------------------
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=eu-west-3
# Local dev bypass: when true, the API trusts a dev JWT/header instead of
# verifying against Cognito. Never enable outside dev.
AUTH_DEV_BYPASS=true

# --- LLM (Mistral AI) -----------------------------------------------------
# Real value lives in Secrets Manager (pilotage/<env>/mistral). See
# docs/providers/mistral.md.
MISTRAL_API_KEY=
MISTRAL_MODEL_SMALL=mistral-small-latest
MISTRAL_MODEL_LARGE=mistral-large-latest
# Per-tenant monthly token cap (cost guardrail).
LLM_TENANT_MONTHLY_TOKEN_CAP=2000000

# --- Payments / billing (Stripe) ------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Accounting connector (Pennylane — OAuth 2.0) -------------------------
# Register an OAuth app at https://app.pennylane.com and whitelist the redirect
# URI ${API_PUBLIC_URL}/connectors/pennylane/callback. Leave unset to run the
# connector in simulation mode (self-issued consent, no live token exchange).
PENNYLANE_CLIENT_ID=
PENNYLANE_CLIENT_SECRET=
# Space-separated scopes; defaults to "read:invoices write:invoices read:products".
# PENNYLANE_SCOPE=read:invoices write:invoices read:products

# --- Open banking connector (Bridge by Bankin' — agrégation DSP2) ---------
# Create an app at https://dashboard.bridgeapi.io and whitelist the callback
# URI ${API_PUBLIC_URL}/connectors/bridge/callback. Leave unset to run the
# connector in simulation mode (self-issued consent, synthetic accounts).
BRIDGE_CLIENT_ID=
BRIDGE_CLIENT_SECRET=
# BRIDGE_BASE_URL=https://api.bridgeapi.io

# --- Messaging (Brevo — SMS / email) --------------------------------------
BREVO_API_KEY=
# Where the public demo/contact form (marketing site) delivers leads.
LEADS_TO_EMAIL=paul@lavopilot.com
LEADS_FROM_EMAIL=no-reply@lavopilot.com

# --- Energy connectors (Enedis Data Connect + GRDF ADICT) -----------------
# Public origins used to build the Enedis consent redirect_uri and the return
# to the web app. redirect_uri must be whitelisted in the Enedis application.
API_PUBLIC_URL=http://localhost:3000
WEB_PUBLIC_URL=http://localhost:5173
# Enedis Data Connect — leave unset to run the connector in simulation mode
# (self-issued consent + synthetic first history). Fill in for the live sandbox.
ENEDIS_CLIENT_ID=
ENEDIS_CLIENT_SECRET=
# ENEDIS_BASE_URL=https://gw.ext.prod-sandbox.api.enedis.fr
# ENEDIS_AUTHORIZE_URL=https://mon-compte-particulier.enedis.fr/dataconnect/v1/oauth2/authorize
# GRDF ADICT — bac à sable credentials ship as code defaults, so this works out
# of the box. Override here with your own client for staging/prod.
# GRDF_ADICT_CLIENT_ID=
# GRDF_ADICT_CLIENT_SECRET=

# --- Web (apps/web) — Vite vars must be prefixed VITE_ ---------------------
VITE_API_BASE_URL=http://localhost:3000
VITE_USE_MOCKS=false
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_REGION=eu-west-3
VITE_AUTH_DEV_BYPASS=true
# Feature flags (comma-separated module keys enabled beyond MVP).
VITE_FEATURE_FLAGS=
