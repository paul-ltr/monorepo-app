{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "sourceMap": true,
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@pilotage/shared": ["packages/shared/src/index.ts"],
      "@pilotage/shared/*": ["packages/shared/src/*"],
      "@pilotage/db": ["packages/db/src/index.ts"],
      "@pilotage/db/*": ["packages/db/src/*"],
      "@pilotage/api-client": ["packages/api-client/src/index.ts"],
      "@pilotage/api-client/*": ["packages/api-client/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".turbo"]
}
