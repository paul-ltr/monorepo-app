{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "noEmit": true,
    "declaration": false,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@pilotage/shared": ["../../packages/shared/src/index.ts"],
      "@pilotage/db": ["../../packages/db/src/index.ts"],
      "@pilotage/api-client": ["../../packages/api-client/src/index.ts"]
    }
  },
  "include": ["src"]
}
